# WordPress REST API base URL (no trailing slash)
NEXT_PUBLIC_WP_URL=https://wpstrona.wpmudev.host/coachandrew

# Optional: WordPress Application Password for authenticated endpoints
# (needed for menus/navigation - see README.md for setup instructions)
# Format: username:application_password
WP_AUTH_TOKEN=

# Optional: Revalidation secret for on-demand ISR via webhook
REVALIDATION_SECRET=your-secret-here

# ── Stripe ────────────────────────────────────────────────────────────
# Get these from stripe.com → Developers → API keys / Products
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID_75=price_...
STRIPE_PRICE_ID_25=price_...

# ── Self-Mastery Profile access codes ────────────────────────────────
# Comma-separated, case-insensitive
ACCESS_CODES=CODE1,CODE2

# ── Calendly ─────────────────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link
